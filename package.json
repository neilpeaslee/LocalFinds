{
  "name": "localfinds",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm -w @localfinds/web run dev",
    "agent": "npm -w @localfinds/agents run agent --",
    "agents:all": "npm -w @localfinds/agents run all",
    "interview": "npm -w @localfinds/agents run interview --",
    "test": "npm -w @localfinds/db run test && npm -w @localfinds/agents run test && npm -w @localfinds/web run test",
    "db:push": "npm -w @localfinds/db run push",
    "db:seed": "npm -w @localfinds/db run seed",
    "db:studio": "npm -w @localfinds/db run studio",
    "boundaries:fetch": "node scripts/fetch-town-boundaries.mjs",
    "deploy": "bash scripts/deploy/deploy.sh",
    "deploy:gate": "bash scripts/deploy/gate.sh",
    "deploy:migrate": "bash scripts/deploy/migrate.sh",
    "deploy:code": "bash scripts/deploy/deploy-code.sh",
    "deploy:sync-content": "bash scripts/deploy/sync-content.sh"
  }
}
