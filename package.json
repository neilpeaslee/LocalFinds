{
  "name": "localfinds",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm -w @localfinds/web run dev",
    "agent": "npm -w @localfinds/agents run agent --",
    "agents:all": "npm -w @localfinds/agents run all",
    "test": "npm -w @localfinds/db run test",
    "db:push": "npm -w @localfinds/db run push",
    "db:seed": "npm -w @localfinds/db run seed",
    "db:studio": "npm -w @localfinds/db run studio",
    "boundaries:fetch": "node scripts/fetch-town-boundaries.mjs"
  }
}
