# LocalFinds deploy config — copy to deploy.env (gitignored) and fill in.
# Infra-specific values live ONLY here, never in committed scripts.

# SSH alias for the server (resolves to the real host via ~/.ssh/config).
DEPLOY_HOST=your-ssh-alias
# App directory on the server (repo root there).
DEPLOY_PATH=/var/www/localfinds
# Bare git repo on the server that deploy-code pushes `main` to. The box
# checkout's `origin` points at this repo's box-local path — set once by the
# one-time git-checkout bootstrap (see the deploy-localfinds skill).
DEPLOY_GIT_REMOTE=your-ssh-alias:repos/YourRepo.git
# Prod Postgres: the re-platform reuses the shared `gis` DB as role `osm_api` (TCP,
# sslmode=disable). No password lives here or in any committed file. On the BOX,
# migrate.sh / pg-backup.sh source a PASSWORD-FREE DSN from ~/localfinds-db.env:
#   export LOCALFINDS_DATABASE_URL=postgresql://osm_api@127.0.0.1:5432/gis?sslmode=disable
# and the password comes from ~/.pgpass (chmod 600), so it never reaches argv/env:
#   127.0.0.1:5432:gis:osm_api:<pw>
# Prepended to every remote node/npm/pm2 command (nvm bootstrap).
DEPLOY_NVM_PREFIX="export NVM_DIR=\$HOME/.nvm; . \$NVM_DIR/nvm.sh;"
# pm2 process name to reload after a deploy.
DEPLOY_PM2_NAME=localfinds
# PATH prefix that puts mise-managed mix on PATH for non-interactive ssh (SP7)
DEPLOY_MIX_PREFIX='export PATH="$HOME/.local/share/mise/shims:$PATH" && '
