# Local development (docker compose db on :5434). Copy the DSN into BOTH:
#   - apps/web/.env.local   (Next only auto-loads .env* from apps/web)
#   - .env                  (agents read the repo-root .env)
# Do not commit the real files (.env / .env.* are gitignored; .example ships).
LOCALFINDS_DATABASE_URL=postgresql://localfinds:localfinds@localhost:5434/localfinds?sslmode=disable

# Needed only to run agents locally (npm run agent ...):
ANTHROPIC_API_KEY=sk-ant-...

# db:pull source (live, over scripts/db-tunnel.sh). Default shown; override if needed:
# LIVE_DATABASE_URL=postgresql://osm_api@localhost:5433/gis?sslmode=disable
