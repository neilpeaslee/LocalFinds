# dependencies / build output
node_modules/
.next/
*.tsbuildinfo
# Next.js auto-generates this and rewrites its path between dev/build runs —
# noisy to track; `next dev`/`next build` regenerate it on any checkout.
next-env.d.ts

# browser-automation debug artifacts
.playwright-mcp/

# brainstorming visual-companion working files
.superpowers/

# secrets / local-only config
.env
.claude/settings.local.json

# internal deploy/ops docs — reference real infra (IPs, hosts); kept local only
docs/superpowers/specs/*deploy-localfinds*
docs/superpowers/plans/*deploy-localfinds*
.claude/skills/deploy-localfinds/

# private strategy docs — competitive positioning / ICP; flag keeps them local on the public repo
*.private.md

# PII boundary: ALL runtime state (db, profiles, notes, logs) stays out of git.
# Only committed templates (*.example) are allowed through.
data/**
!data/**/
!data/**/*.example
