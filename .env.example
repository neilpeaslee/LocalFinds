# Anthropic API key used by the gathering agents (packages/agents)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override where runtime data (sqlite db + agent workspaces) lives.
# Defaults to <repo>/data
# LOCALFINDS_DATA_DIR=/abs/path/to/data

# LocalFinds Postgres — the single system of record (packages/db reads this).
# On the dev box, agents reach the PROD DB through an SSH tunnel so Postgres is
# never exposed publicly: run scripts/db-tunnel.sh (forwards localhost:5433 ->
# the server's localhost:5432), then set the tunnelled DSN below. The real value
# and the tunnel are local-only — never commit real credentials.
# LOCALFINDS_DATABASE_URL=postgres://<user>:<pass>@localhost:5433/localfinds
